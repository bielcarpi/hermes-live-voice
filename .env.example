# Hermes Agent API Server
HERMES_BASE_URL=http://127.0.0.1:8642
# Set this to Hermes Agent's API_SERVER_KEY.
HERMES_AGENT_API_SERVER_KEY=
HERMES_LIVE_RUN_INSTRUCTIONS=
HERMES_LIVE_HERMES_TIMEOUT_MS=30000

# hermes-live gateway
HERMES_LIVE_HOST=127.0.0.1
HERMES_LIVE_PORT=8788
# Required for network-accessible binds; use a high-entropy value.
HERMES_LIVE_AUTH_TOKEN=
# Unsafe opt-out for isolated trusted networks only. Leave false/empty for public or LAN binds.
HERMES_LIVE_ALLOW_UNAUTHENTICATED=false
HERMES_LIVE_ALLOW_ORIGIN=
HERMES_LIVE_MAX_AUDIO_BYTES=2000000
HERMES_LIVE_MAX_TEXT_CHARS=20000
HERMES_LIVE_PROVIDER_READY_TIMEOUT_MS=15000
HERMES_LIVE_DEMO_ENABLED=true

# Realtime provider: "gemini", "openai", "local", or "mock".
HERMES_LIVE_PROVIDER=gemini

# Gemini Live
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-live-preview

# OpenAI Realtime
OPENAI_API_KEY=
OPENAI_REALTIME_BASE_URL=wss://api.openai.com/v1/realtime
# Use gpt-realtime-1.5 for current Realtime 1.x sessions or gpt-realtime-2 for Realtime 2 reasoning sessions.
OPENAI_REALTIME_MODEL=gpt-realtime-2
OPENAI_REALTIME_VOICE=echo
# Realtime 2 reasoning effort: minimal, low, medium, high, or xhigh.
OPENAI_REALTIME_REASONING_EFFORT=low
# disabled keeps push-to-talk behavior; semantic_vad or server_vad enables provider turn detection.
OPENAI_REALTIME_TURN_DETECTION=disabled
OPENAI_REALTIME_INPUT_AUDIO_FORMAT=pcm16
# Local Speech-to-Speech (hf-realtime-voice backend — started automatically by run.sh)
# run.sh starts backend/speech-to-speech and wires HERMES_LOCAL_REALTIME_BASE_URL automatically.
# You only need to set the LLM credentials the backend will use for reasoning.
HERMES_LOCAL_REALTIME_BASE_URL=ws://127.0.0.1:8765/v1/realtime
HERMES_LOCAL_REALTIME_VOICE=Aiden
# Port the speech-to-speech backend binds on (default 8765, must match HERMES_LOCAL_REALTIME_BASE_URL)
HERMES_LOCAL_REALTIME_PORT=8765

# LLM credentials for the local speech-to-speech backend (used when HERMES_LIVE_PROVIDER=local)
# Any OpenAI-compatible provider works — OpenRouter is the default.
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-oss-120b:nitro

# Optional Vertex/Gemini Enterprise mode

# Optional Vertex/Gemini Enterprise mode
# GOOGLE_GENAI_USE_ENTERPRISE=true
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_LOCATION=us-central1
