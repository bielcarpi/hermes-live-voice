# Hermes Agent API Server
HERMES_BASE_URL=http://127.0.0.1:8642
HERMES_API_KEY=
HERMES_LIVE_RUN_INSTRUCTIONS=
HERMES_LIVE_HERMES_TIMEOUT_MS=30000

# hermes-live gateway
HERMES_LIVE_HOST=127.0.0.1
HERMES_LIVE_PORT=8788
HERMES_LIVE_AUTH_TOKEN=
HERMES_LIVE_ALLOW_ORIGIN=
HERMES_LIVE_DEMO_ENABLED=true

# Realtime provider: "gemini", "openai", or "mock".
HERMES_LIVE_PROVIDER=gemini

# Gemini Live
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-live-preview

# OpenAI Realtime
OPENAI_API_KEY=
OPENAI_REALTIME_BASE_URL=wss://api.openai.com/v1/realtime
# Use gpt-realtime for Realtime 1 style sessions or gpt-realtime-2 for Realtime 2 reasoning sessions.
OPENAI_REALTIME_MODEL=gpt-realtime-2
OPENAI_REALTIME_VOICE=marin
# Realtime 2 reasoning effort: none, minimal, low, medium, high, or xhigh.
OPENAI_REALTIME_REASONING_EFFORT=low
# disabled keeps push-to-talk behavior; semantic_vad or server_vad enables provider turn detection.
OPENAI_REALTIME_TURN_DETECTION=disabled
OPENAI_REALTIME_INPUT_AUDIO_FORMAT=pcm16
OPENAI_REALTIME_OUTPUT_AUDIO_FORMAT=pcm16

# Optional Vertex/Gemini Enterprise mode
# GOOGLE_GENAI_USE_ENTERPRISE=true
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_LOCATION=us-central1
