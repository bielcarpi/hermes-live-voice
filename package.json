{
  "name": "hermes-live-voice",
  "version": "0.2.1",
  "description": "Realtime voice bridge for Hermes Agent with Gemini Live, OpenAI Realtime, barge-in, tools, memory, and approvals.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "license": "MIT",
  "author": {
    "name": "Biel Carpi",
    "url": "https://github.com/bielcarpi"
  },
  "homepage": "https://github.com/bielcarpi/hermes-live-voice#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bielcarpi/hermes-live-voice.git"
  },
  "bugs": {
    "url": "https://github.com/bielcarpi/hermes-live-voice/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "hermes-agent",
    "gemini-live",
    "openai-realtime",
    "realtime",
    "voice",
    "hermes-plugin",
    "speech-to-speech",
    "voice-agent",
    "full-duplex",
    "barge-in",
    "agent",
    "websocket"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "hermes-live": "./dist/cli.js"
  },
  "files": [
    "dist",
    "apps/web-demo/app.js",
    "apps/web-demo/index.html",
    "apps/web-demo/mic-worklet.js",
    "apps/web-demo/styles.css",
    "assets",
    "docs",
    "examples",
    "plugins/hermes-live",
    "scripts",
    "!plugins/hermes-live/__pycache__",
    "!plugins/hermes-live/**/*.pyc",
    "LICENSE",
    "README.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "SUPPORT.md",
    "SECURITY.md",
    "CODE_OF_CONDUCT.md",
    ".env.example"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "dev": "tsx src/cli.ts dev",
    "start": "node dist/cli.js serve",
    "check": "tsx src/cli.ts check",
    "check:cli-check": "node scripts/cli-check-smoke.mjs",
    "check:cli-client": "node scripts/cli-client-smoke.mjs",
    "check:gateway": "node scripts/gateway-smoke.mjs",
    "check:docs": "node scripts/docs-check.mjs",
    "check:live-provider": "npm run build && node dist/cli.js provider-smoke",
    "check:live-provider-cli": "node scripts/live-provider-cli-smoke.mjs",
    "check:package": "node scripts/package-smoke.mjs",
    "check:plugin": "python3 scripts/plugin-smoke.py",
    "check:web-demo": "node --check apps/web-demo/app.js && node --check apps/web-demo/mic-worklet.js",
    "print-config": "tsx src/cli.ts print-config",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "verify": "npm run typecheck && npm run check:docs && npm run check:web-demo && npm run check:plugin && npm test && npm run build && npm run check:live-provider-cli && npm run check:cli-check && npm run check:cli-client && npm run check:gateway && npm run check:package",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@google/genai": "^2.11.0",
    "ws": "^8.18.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.23.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
