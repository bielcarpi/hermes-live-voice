{
  "name": "hermes-live",
  "version": "0.1.0",
  "description": "Hermes Agent plugin and realtime voice gateway powered by pluggable live providers.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "license": "MIT",
  "author": "Hermes Live contributors",
  "homepage": "https://github.com/bielcarpi/hermes-live#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bielcarpi/hermes-live.git"
  },
  "bugs": {
    "url": "https://github.com/bielcarpi/hermes-live/issues"
  },
  "keywords": [
    "hermes-agent",
    "gemini-live",
    "openai-realtime",
    "realtime",
    "voice",
    "hermes-plugin",
    "agent",
    "websocket"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "hermes-live": "./dist/cli.js"
  },
  "files": [
    "dist",
    "apps/web-demo",
    "docs",
    "examples",
    "plugins/hermes-live",
    "scripts",
    "!plugins/hermes-live/__pycache__",
    "!plugins/hermes-live/**/*.pyc",
    "LICENSE",
    "README.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "CODE_OF_CONDUCT.md",
    ".env.example"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "dev": "tsx src/cli.ts dev",
    "start": "node dist/cli.js serve",
    "check": "tsx src/cli.ts check",
    "check:cli-check": "node scripts/cli-check-smoke.mjs",
    "check:cli-client": "node scripts/cli-client-smoke.mjs",
    "check:gateway": "node scripts/gateway-smoke.mjs",
    "check:package": "node scripts/package-smoke.mjs",
    "check:plugin": "python3 scripts/plugin-smoke.py",
    "check:web-demo": "node --check apps/web-demo/app.js && node --check apps/web-demo/mic-worklet.js",
    "print-config": "tsx src/cli.ts print-config",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "verify": "npm run typecheck && npm run check:web-demo && npm run check:plugin && npm test && npm run build && npm run check:cli-check && npm run check:cli-client && npm run check:gateway && npm run check:package",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@google/genai": "^1.24.0",
    "ws": "^8.18.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
